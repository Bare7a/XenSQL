<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="xensql"
        Arguments=""
        InstallLocation="C:\Program Files\Bare7a\XenSQL">
    </Installer>
    <PackageInformation
        PackageName="XenSQL"
        PackageDisplayName="XenSQL"
        PublisherName="CN=Bare7a"
        PublisherDisplayName="Bare7a"
        Version="1.1.2.0"
        PackageDescription="A fast, native SQL client built with Go, Wails and React.">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.bare7a.xensql"
                Description="A fast, native SQL client built with Go, Wails and React."
                DisplayName="XenSQL"
                ExecutableName="xensql"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>XenSQL</DisplayName>
            <PublisherDisplayName>Bare7a</PublisherDisplayName>
            <Description>A fast, native SQL client built with Go, Wails and React.</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="xensql.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
