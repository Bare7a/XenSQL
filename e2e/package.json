{
  "name": "xensql-e2e",
  "private": true,
  "type": "module",
  "description": "Playwright end-to-end tests for XenSQL (drives the app in Wails v3 server mode).",
  "scripts": {
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:server": "node e2e-server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
