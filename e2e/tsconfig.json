{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    // Playwright resolves these too, so nested specs import '@support/…' instead of '../../…'.
    "paths": {
      "@support/*": ["./support/*"]
    }
  },
  "include": ["**/*.ts"]
}
